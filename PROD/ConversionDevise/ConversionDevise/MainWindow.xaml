<Window
    x:Class="ConversionDevise.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ConversionDevise"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title=""
    Width="800"
    Height="450"
    Background="{DynamicResource MaterialDesignPaper}"
    Icon="https://cdn-icons-png.flaticon.com/512/1549/1549755.png"
    TextElement.FontSize="13"
    TextElement.FontWeight="Regular"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    TextOptions.TextFormattingMode="Ideal"
    TextOptions.TextRenderingMode="Auto"
    mc:Ignorable="d">
    <Grid>
        <StackPanel>
            <DockPanel>
                <materialDesign:PopupBox
                    DockPanel.Dock="Left"
                    PlacementMode="BottomAndAlignLeftEdges"
                    StaysOpen="False">
                    <StackPanel>
                        <Button Content="€ -> Devise"/>
                        <Button Content="Devise -> €"/>
                        <Separator />
                        <Button Content="Devises"/>
                    </StackPanel>
                </materialDesign:PopupBox>
            </DockPanel>
        </StackPanel>
    </Grid>
</Window>
